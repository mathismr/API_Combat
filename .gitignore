# ----------------------------
# Python bytecode / caches
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.pytype/
.pyre/

# ----------------------------
# Virtual environments
# ----------------------------
.venv/
venv/
env/
ENV/

# ----------------------------
# Packaging / build artifacts
# ----------------------------
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ----------------------------
